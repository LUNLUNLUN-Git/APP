// --------- WebXR check ---------
async function checkXRSupport() {
  const statusText = $('#status-text');
  const statusDot = $('#status-dot');
  const statusDetail = $('#status-detail');

  if (!navigator.xr) {
    statusText.textContent = 'NO WEBXR';
    statusDot.classList.add('warn');
    statusDetail.textContent = 'USE CHROME / ANDROID';
    state.xrSupported = false;
    return;
  }

  try {
    const supported = await navigator.xr.isSessionSupported('immersive-ar');
    if (supported) {
      statusText.textContent = 'AR READY';
      statusDot.classList.add('ok');
      statusDetail.textContent = 'WEBXR // HIT-TEST';
      state.xrSupported = true;
    } else {
      statusText.textContent = 'AR UNSUPPORTED';
      statusDot.classList.add('warn');
      statusDetail.textContent = 'FALLBACK MODE';
      state.xrSupported = false;
    }
  } catch (e) {
    statusText.textContent = 'CHECK FAILED';
    statusDot.classList.add('warn');
    statusDetail.textContent = 'FALLBACK MODE';
    state.xrSupported = false;
  }
}

// --------- Launch an experience ---------
async function launchExperience(exp) {
  state.experience = exp;
  resetExperienceState();

  $('#hud-exp-name').textContent = exp.title.toUpperCase();
  $('#hud-counter-label').textContent = exp.hudLabel;
  $('#hud-counter').textContent = '0';
