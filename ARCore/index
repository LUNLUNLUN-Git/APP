  state.pet = { pets: [] };
  state.color = '#ff8c42';
  state.scale = 1;
}

// --------- Initialize WebXR AR ---------
async function initXR() {
  const canvas = document.createElement('canvas');
  canvas.style.position = 'fixed';
  canvas.style.inset = '0';
  canvas.style.width = '100%';
  canvas.style.height = '100%';
  canvas.style.zIndex = '50';
  document.body.appendChild(canvas);
  state.canvas = canvas;

  const context = canvas.getContext('webgl2', { xrCompatible: true, antialias: true });
  state.renderer = new THREE.WebGLRenderer({ canvas, context, antialias: true, alpha: true });
  state.renderer.setPixelRatio(window.devicePixelRatio);
  state.renderer.setSize(window.innerWidth, window.innerHeight);
  state.renderer.xr.enabled = true;
  state.renderer.outputColorSpace = THREE.SRGBColorSpace;
  state.renderer.toneMapping = THREE.ACESFilmicToneMapping;

  state.scene = new THREE.Scene();
  state.camera = new THREE.PerspectiveCamera(70, window.innerWidth / window.innerHeight, 0.01, 40);

  // Lights
  const ambient = new THREE.HemisphereLight(0xffffff, 0x444422, 1.2);
  state.scene.add(ambient);
  const directional = new THREE.DirectionalLight(0xffffff, 1.5);
  directional.position.set(1, 2, 1);
  state.scene.add(directional);

  // Reticle
  const ringGeom = new THREE.RingGeometry(0.09, 0.1, 32).rotateX(-Math.PI / 2);
  const ringMat = new THREE.MeshBasicMaterial({ color: 0xff8c42, transparent: true, opacity: 0.9 });
  state.reticle = new THREE.Mesh(ringGeom, ringMat);
  state.reticle.matrixAutoUpdate = false;
  state.reticle.visible = false;

  // Inner dot
  const dotGeom = new THREE.CircleGeometry(0.012, 16).rotateX(-Math.PI / 2);
  const dotMat = new THREE.MeshBasicMaterial({ color: 0xff8c42 });
  const dot = new THREE.Mesh(dotGeom, dotMat);
  state.reticle.add(dot);

  state.scene.add(state.reticle);

  // Session
  state.session = await navigator.xr.requestSession('immersive-ar', {
    requiredFeatures: ['hit-test', 'local'],
    optionalFeatures: ['dom-overlay', 'light-estimation'],
    domOverlay: { root: $('#ar-overlay') }
  });
  state.renderer.xr.setReferenceSpaceType('local');
  await state.renderer.xr.setSession(state.session);
  state.inSession = true;

  // Hit test source
  const viewerSpace = await state.session.requestReferenceSpace('viewer');
  state.hitTestSource = await state.session.requestHitTestSource({ space: viewerSpace });
  state.referenceSpace = await state.session.requestReferenceSpace('local');

  // Controller for taps
  state.controller = state.renderer.xr.getController(0);
  state.controller.addEventListener('select', onSelect);
  state.controller.addEventListener('selectstart', onSelectStart);
  state.controller.addEventListener('selectend', onSelectEnd);
  state.scene.add(state.controller);

  state.session.addEventListener('end', onSessionEnd);

  state.renderer.setAnimationLoop(renderLoop);
}

// --------- Fallback mode (non-AR) ---------
function initFallback() {
  const canvas = document.createElement('canvas');
  canvas.style.position = 'fixed';
  canvas.style.inset = '0';
  canvas.style.width = '100%';
  canvas.style.height = '100%';
  canvas.style.zIndex = '50';
  canvas.style.background = 'linear-gradient(180deg, #1a1a1d 0%, #0a0a0b 100%)';
  document.body.appendChild(canvas);
  state.canvas = canvas;

  state.renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
  state.renderer.setPixelRatio(window.devicePixelRatio);
  state.renderer.setSize(window.innerWidth, window.innerHeight);
  state.renderer.outputColorSpace = THREE.SRGBColorSpace;

  state.scene = new THREE.Scene();

  // Add grid floor for fallback
  const gridHelper = new THREE.GridHelper(10, 20, 0xff8c42, 0x222222);
  gridHelper.position.y = -1;
  state.scene.add(gridHelper);

  state.camera = new THREE.PerspectiveCamera(70, window.innerWidth / window.innerHeight, 0.01, 100);
  state.camera.position.set(0, 0, 2);

  const ambient = new THREE.HemisphereLight(0xffffff, 0x444444, 1.2);
  state.scene.add(ambient);
  const directional = new THREE.DirectionalLight(0xffffff, 1.2);
  directional.position.set(1, 2, 1);
  state.scene.add(directional);

  // Reticle points at (0,-0.5,-1) fixed in fallback
  const ringGeom = new THREE.RingGeometry(0.09, 0.1, 32).rotateX(-Math.PI / 2);
  const ringMat = new THREE.MeshBasicMaterial({ color: 0xff8c42, transparent: true, opacity: 0.9 });
  state.reticle = new THREE.Mesh(ringGeom, ringMat);
  state.reticle.position.set(0, -0.5, -1);
  state.reticle.visible = true;
  state.scene.add(state.reticle);

  // OrbitControls for exploration
  state.controls = new OrbitControls(state.camera, canvas);
  state.controls.enableDamping = true;
  state.controls.dampingFactor = 0.1;
  state.controls.target.set(0, 0, -1);

  // Try to use device orientation for "pseudo-AR"
  tryDeviceOrientation();

  // Fake touch as "select"
  canvas.addEventListener('pointerdown', (e) => {
    if (e.target !== canvas) return;
    onSelectStart();
  });
  canvas.addEventListener('pointerup', (e) => {
    onSelectEnd();
    onSelect();
  });

  $('#instruction-text').innerHTML = '⚠ 非 AR 模式<br>可拖曳畫面探索，點擊互動';

  state.renderer.setAnimationLoop(renderLoop);
}

// Optional: use device orientation for pseudo-AR look-around
function tryDeviceOrientation() {
  if (typeof DeviceOrientationEvent !== 'undefined' &&
      typeof DeviceOrientationEvent.requestPermission === 'function') {
    // iOS 13+ needs explicit permission, but we'll just let OrbitControls handle it.
  }
}

function onSessionEnd() {
  state.inSession = false;
  state.session = null;
  cleanupAR();
  state.experience = null;
  state.hadFirstHit = false;
  $('#ar-overlay').classList.remove('active');
  $('#ar-instruction').classList.remove('hidden');
  $('#scale-row').style.display = 'none';
}

// --------- Cleanup ---------
function cleanupAR() {
  if (state.renderer) {
    state.renderer.setAnimationLoop(null);
    if (state.canvas && state.canvas.parentNode) {
      state.canvas.parentNode.removeChild(state.canvas);
    }
    state.renderer.dispose();
  }
  state.scene = null;
  state.camera = null;
  state.renderer = null;
  state.reticle = null;
  state.hitTestSource = null;
  state.controller = null;
  state.session = null;
}

// --------- Main render loop ---------
function renderLoop(timestamp, frame) {
  if (!state.renderer) return;

  // FPS
  state.frameCount++;
  if (timestamp - state.lastFpsUpdate > 500) {
    state.fps = Math.round(state.frameCount * 1000 / (timestamp - state.lastFpsUpdate));
    state.frameCount = 0;
    state.lastFpsUpdate = timestamp;
  }
  const dt = Math.min(0.1, (timestamp - state.lastFrame) / 1000);
  state.lastFrame = timestamp;

  // Hit test
  if (frame && state.hitTestSource) {
    const hits = frame.getHitTestResults(state.hitTestSource);
    if (hits.length > 0) {
      const pose = hits[0].getPose(state.referenceSpace);
      state.reticle.visible = state.experience.id !== 'draw' || !state.drawing.isDrawing;
      state.reticle.matrix.fromArray(pose.transform.matrix);

      // Update coords display
      const m = pose.transform.position;
      $('#ar-coords').innerHTML = `X: ${m.x.toFixed(2)}<br>Y: ${m.y.toFixed(2)}<br>Z: ${m.z.toFixed(2)}<br>FPS: ${state.fps}`;

      // Hide instruction on first hit
      if (!state.hadFirstHit) {
        state.hadFirstHit = true;
        setTimeout(() => $('#ar-instruction').classList.add('hidden'), 500);
      }
    } else {
      state.reticle.visible = false;
    }
  } else if (!frame) {
    // Fallback mode
    $('#ar-coords').innerHTML = `FALLBACK MODE<br>FPS: ${state.fps}`;
    if (state.controls) state.controls.update();
  }

  // Experience update
  if (state.experience) {
    updateExperience(state.experience, dt, timestamp);
  }

  state.renderer.render(state.scene, state.camera);
}

// --------- On select ---------
function onSelect() {
  if (!state.experience) return;

  // Get reticle position / direction
  const pos = new THREE.Vector3();
  const quat = new THREE.Quaternion();
  const matrix = new THREE.Matrix4().fromArray(state.reticle.matrix.elements);
  matrix.decompose(pos, quat, new THREE.Vector3());

  // Only allow if reticle visible (i.e. we have a hit)
  if (!state.reticle.visible && state.xrSupported && state.experience.id !== 'laser' && state.experience.id !== 'draw') {
    toast('請先瞄準平面');
    return;
  }

  handleSelect(state.experience, pos, quat);
  updateCounter();
}

function onSelectStart() {
  if (state.experience?.id === 'draw') {
    startDrawStroke();
  } else if (state.experience?.id === 'laser') {
    state.laser.holding = true;
  }
}

function onSelectEnd() {
  if (state.experience?.id === 'draw') {
    endDrawStroke();
  } else if (state.experience?.id === 'laser') {
    state.laser.holding = false;
  }
}

// --------- Exit experience ---------
function exitExperience() {
  // Guard against re-entry
  if (!state.experience && !state.renderer && !state.session) return;

  if (state.session && state.inSession) {
    state.inSession = false; // prevent loop from onSessionEnd
    state.session.end().catch(() => {});
  } else {
    cleanupAR();
  }
  state.experience = null;
  state.hadFirstHit = false;
  $('#ar-overlay').classList.remove('active');
  $('#ar-instruction').classList.remove('hidden');
  $('#scale-row').style.display = 'none';
}

// --------- Toolbar construction ---------
function buildToolbar(exp) {
  const tb = $('#ar-toolbar');
  tb.innerHTML = '';
  $('#scale-row').style.display = 'none';

  (exp.tools || []).forEach(tool => {
    if (tool === 'scale') {
      $('#scale-row').style.display = 'flex';
      const slider = $('#scale-slider');
      const val = $('#scale-value');
      slider.value = 1;
      val.textContent = '1.0x';
      slider.oninput = () => {
        state.scale = parseFloat(slider.value);
        val.textContent = state.scale.toFixed(1) + 'x';
        // Apply to last placed object if object placement
        if (exp.id === 'placement' && state.objects.length > 0) {
          const last = state.objects[state.objects.length - 1];
          last.scale.setScalar(state.scale);
        }
      };
      return;
    }

    const btn = document.createElement('button');
    btn.className = 'ar-tool';
    btn.dataset.tool = tool;

    switch (tool) {
      case 'shape':
        btn.innerHTML = `<svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>`;
        btn.title = 'Shape';
        btn.onclick = () => cycleShape(btn);
        btn.dataset.shape = 'cube';
        break;
      case 'color':
        btn.className += ' color-swatch active';
        btn.style.background = state.color;
        btn.innerHTML = '';
        btn.onclick = () => cycleColor(btn);
        break;
      case 'scale':
        break;
      case 'delete':
        btn.innerHTML = `<svg viewBox="0 0 24 24"><path d="M3 6h18M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2m3 0v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6h14z"/></svg>`;
        btn.onclick = deleteLast;
        break;
      case 'capture':
        btn.innerHTML = `<svg viewBox="0 0 24 24"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>`;
        btn.onclick = captureScreenshot;
        break;
      case 'undo':
        btn.innerHTML = `<svg viewBox="0 0 24 24"><path d="M3 7v6h6M3 13a9 9 0 109-9"/></svg>`;
        btn.onclick = undoAction;
        break;
      case 'clear':
        btn.innerHTML = `<svg viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" stroke="none" fill="currentColor"/></svg>`;
        btn.onclick = clearAll;
        break;
      case 'thickness':
        btn.innerHTML = `<svg viewBox="0 0 24 24"><path d="M3 12h18" stroke-width="3"/></svg>`;
        btn.onclick = () => cycleThickness(btn);
        break;
      case 'mode':
        btn.innerHTML = `<svg viewBox="0 0 24 24"><path d="M6 6l12 12M6 12l12 0M6 18l12-12"/></svg>`;
        btn.onclick = () => cycleLaserMode(btn);
        break;
      case 'preset':
        btn.innerHTML = `<svg viewBox="0 0 24 24"><path d="M12 2v20M2 12h20"/></svg>`;
        btn.onclick = () => cyclePreset(btn);
        break;
      case 'scene':
        btn.innerHTML = `<svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2zM3 15l4-4 4 4 4-4 6 6"/></svg>`;
        btn.onclick = () => cyclePortalScene(btn);
        break;
      case 'shoot':
        btn.innerHTML = `<svg viewBox="0 0 24 24"><path d="M12 2L2 22h20L12 2z"/><circle cx="12" cy="15" r="2" fill="currentColor"/></svg>`;
        btn.onclick = shootBall;
        break;
      case 'trick':
        btn.innerHTML = `<svg viewBox="0 0 24 24"><path d="M12 2l2 7h7l-5.5 4 2 7L12 16l-5.5 4 2-7L3 9h7z"/></svg>`;
        btn.onclick = petTrick;
        break;
    }
    tb.appendChild(btn);
  });
}

// --------- Toolbar actions ---------
const SHAPES = ['cube', 'sphere', 'cylinder', 'cone', 'torus'];
function cycleShape(btn) {
  const i = SHAPES.indexOf(btn.dataset.shape);
  btn.dataset.shape = SHAPES[(i + 1) % SHAPES.length];
  toast('形狀: ' + btn.dataset.shape.toUpperCase());
}

const COLORS = ['#ff8c42', '#5eead4', '#f87171', '#fbbf24', '#a78bfa', '#60a5fa', '#ffffff', '#1a1a1a'];
function cycleColor(btn) {
  const i = COLORS.indexOf(state.color);
  state.color = COLORS[(i + 1) % COLORS.length];
  btn.style.background = state.color;
  toast('顏色已切換');
}

function cycleThickness(btn) {
  const options = [0.005, 0.008, 0.015, 0.025];
  const i = options.indexOf(state.drawing.thickness);
  state.drawing.thickness = options[(i + 1) % options.length];
  toast('粗細: ' + (state.drawing.thickness * 1000).toFixed(0) + 'mm');
}

function cycleLaserMode(btn) {
  const modes = ['single', 'rapid', 'spread'];
  const i = modes.indexOf(state.laser.mode);
  state.laser.mode = modes[(i + 1) % modes.length];
  toast('模式: ' + state.laser.mode.toUpperCase());
}

function cyclePreset(btn) {
  const presets = ['fountain', 'fire', 'snow', 'smoke'];
  const i = presets.indexOf(state.particles.preset);
  state.particles.preset = presets[(i + 1) % presets.length];
  toast('預設: ' + state.particles.preset.toUpperCase());
}

function cyclePortalScene(btn) {
  const scenes = ['nebula', 'ocean', 'matrix'];
  state.portalSceneType = state.portalSceneType || 'nebula';
  const i = scenes.indexOf(state.portalSceneType);
  state.portalSceneType = scenes[(i + 1) % scenes.length];
  toast('場景: ' + state.portalSceneType.toUpperCase());
}

function deleteLast() {
  if (state.experience.id === 'placement' && state.objects.length > 0) {
    const obj = state.objects.pop();
    state.scene.remove(obj);
    updateCounter();
  }
}

function undoAction() {
  if (state.experience.id === 'draw' && state.drawing.strokes.length > 0) {
    const stroke = state.drawing.strokes.pop();
    state.scene.remove(stroke);
  } else if (state.experience.id === 'measure' && state.measure.lines.length > 0) {
    const line = state.measure.lines.pop();
    line.children.forEach(c => state.scene.remove(c));
    state.scene.remove(line);
    state.measure.points = [];
  }
  updateCounter();
}

function clearAll() {
  const exp = state.experience.id;
  if (exp === 'draw') {
    state.drawing.strokes.forEach(s => state.scene.remove(s));
    state.drawing.strokes = [];
  } else if (exp === 'measure') {
    state.measure.lines.forEach(l => {
      l.children.slice().forEach(c => state.scene.remove(c));
      state.scene.remove(l);
    });
    state.measure.lines = [];
    state.measure.points = [];
  } else if (exp === 'physics') {
    state.physics.balls.forEach(b => state.scene.remove(b));
    state.physics.balls = [];
    state.physics.floorSet = false;
    state.physics.floorY = null;
  } else if (exp === 'laser') {
    state.laser.shots.forEach(s => state.scene.remove(s));
    state.laser.shots = [];
  } else if (exp === 'particles') {
    state.particles.emitters.forEach(e => state.scene.remove(e));
    state.particles.emitters = [];
  } else if (exp === 'pet') {
    state.pet.pets.forEach(p => state.scene.remove(p));
    state.pet.pets = [];
  }
  updateCounter();
  toast('已清除');
}

function updateCounter() {
  const exp = state.experience.id;
  let count = 0;
  if (exp === 'placement') count = state.objects.length;
  else if (exp === 'draw') count = state.drawing.strokes.length;
  else if (exp === 'measure') count = state.measure.lines.length;
  else if (exp === 'physics') count = state.physics.balls.length;
  else if (exp === 'laser') count = state.laser.shots.length;
  else if (exp === 'particles') count = state.particles.emitters.length;
  else if (exp === 'pet') count = state.pet.pets.length;
  else if (exp === 'portal') count = state.objects.length;
  $('#hud-counter').textContent = count;
}

// --------- Experience initialization ---------
function initExperience(exp) {
  if (exp.id === 'portal') initPortalSceneResources();
}

// --------- Selection handlers per experience ---------
function handleSelect(exp, pos, quat) {
  switch (exp.id) {
    case 'placement': placeObject(pos, quat); break;
    case 'measure': addMeasurePoint(pos); break;
    case 'portal': placePortal(pos, quat); break;
    case 'physics': handlePhysicsSelect(pos, quat); break;
    case 'laser': fireLaser(pos, quat); break;
    case 'particles': placeEmitter(pos); break;
    case 'pet': placePet(pos); break;
  }
}

// --------- 1. Object Placement ---------
function placeObject(pos, quat) {
  const shapeBtn = $('[data-tool="shape"]');
  const shape = shapeBtn ? shapeBtn.dataset.shape : 'cube';
  let geom;
  switch (shape) {
    case 'sphere': geom = new THREE.SphereGeometry(0.08, 24, 16); break;
    case 'cylinder': geom = new THREE.CylinderGeometry(0.07, 0.07, 0.16, 24); break;
    case 'cone': geom = new THREE.ConeGeometry(0.08, 0.16, 24); break;
    case 'torus': geom = new THREE.TorusGeometry(0.08, 0.03, 12, 32); break;
    default: geom = new THREE.BoxGeometry(0.14, 0.14, 0.14);
  }
  const color = new THREE.Color(state.color);
  const mat = new THREE.MeshStandardMaterial({
    color,
    metalness: 0.2,
    roughness: 0.4,
    emissive: color,
    emissiveIntensity: 0.1
  });
  const mesh = new THREE.Mesh(geom, mat);
  mesh.position.copy(pos);
  mesh.position.y += 0.08;
  mesh.quaternion.copy(quat);
  mesh.scale.setScalar(state.scale);
  mesh.userData.spawnTime = performance.now();

  // Add subtle ring base
  const ringG = new THREE.RingGeometry(0.09, 0.095, 32).rotateX(-Math.PI / 2);
  const ringM = new THREE.MeshBasicMaterial({ color: 0xff8c42, transparent: true, opacity: 0.6 });
  const ring = new THREE.Mesh(ringG, ringM);
  ring.position.copy(pos);
  mesh.add(ring);
  ring.position.set(0, -0.08, 0);

  state.scene.add(mesh);
  state.objects.push(mesh);
}

// --------- 2. Measure ---------
function addMeasurePoint(pos) {
  state.measure.points.push(pos.clone());

  // Add dot
  const dotG = new THREE.SphereGeometry(0.015, 12, 8);
  const dotM = new THREE.MeshBasicMaterial({ color: 0xff8c42 });
  const dot = new THREE.Mesh(dotG, dotM);
  dot.position.copy(pos);
  state.scene.add(dot);

  if (state.measure.points.length === 2) {
    const [a, b] = state.measure.points;
    const dist = a.distanceTo(b);

    // Line
    const lineGeom = new THREE.BufferGeometry().setFromPoints([a, b]);
    const lineMat = new THREE.LineBasicMaterial({ color: 0xff8c42 });
    const line = new THREE.Line(lineGeom, lineMat);

    // Label (using sprite with canvas texture)
    const canvas = document.createElement('canvas');
    canvas.width = 256; canvas.height = 64;
    const ctx = canvas.getContext('2d');
    ctx.fillStyle = 'rgba(10,10,11,0.9)';
    ctx.fillRect(0, 0, 256, 64);
    ctx.strokeStyle = '#ff8c42';
    ctx.lineWidth = 2;
    ctx.strokeRect(2, 2, 252, 60);
    ctx.fillStyle = '#ff8c42';
    ctx.font = 'bold 28px monospace';
    ctx.textAlign = 'center';
    ctx.fillText(`${(dist * 100).toFixed(1)} cm`, 128, 40);
    const tex = new THREE.CanvasTexture(canvas);
    const sprMat = new THREE.SpriteMaterial({ map: tex, transparent: true });
    const sprite = new THREE.Sprite(sprMat);
    sprite.position.copy(a).lerp(b, 0.5);
    sprite.position.y += 0.04;
    sprite.scale.set(0.15, 0.04, 1);

    const group = new THREE.Group();
    group.add(line);
    state.scene.add(line);
    state.scene.add(sprite);
    group.children.push(sprite, dot); // track for cleanup

    state.measure.lines.push(group);
    state.measure.points = [];

    toast(`距離: ${(dist * 100).toFixed(1)} cm`);
  }
}

// --------- 3. Draw ---------
function startDrawStroke() {
  state.drawing.isDrawing = true;
  state.drawing.currentPoints = [];
  // We'll build a tube once stroke ends. For real-time feedback use Line
  const geom = new THREE.BufferGeometry();
  const mat = new THREE.LineBasicMaterial({
    color: state.color,
    linewidth: 3,
    transparent: true,
    opacity: 0.8
  });
  const line = new THREE.Line(geom, mat);
  state.drawing.currentLine = line;
  state.scene.add(line);
  $('#ar-instruction').classList.add('hidden');
}

function updateDrawStroke() {
  if (!state.drawing.isDrawing) return;
  const { pos: camPos, quat: camQuat } = getCameraPose();
  const forward = new THREE.Vector3(0, 0, -0.25).applyQuaternion(camQuat);
  const drawPos = camPos.clone().add(forward);

  const pts = state.drawing.currentPoints;
  if (pts.length === 0 || pts[pts.length - 1].distanceTo(drawPos) > 0.01) {
    pts.push(drawPos);
    const geom = new THREE.BufferGeometry().setFromPoints(pts);
    state.drawing.currentLine.geometry.dispose();
    state.drawing.currentLine.geometry = geom;
  }
}

function endDrawStroke() {
  if (!state.drawing.isDrawing) return;
  state.drawing.isDrawing = false;

  const pts = state.drawing.currentPoints;
  if (pts.length < 2) {
    if (state.drawing.currentLine) state.scene.remove(state.drawing.currentLine);
    return;
  }

  // Build smooth tube
  state.scene.remove(state.drawing.currentLine);
  const curve = new THREE.CatmullRomCurve3(pts);
  const tubeGeom = new THREE.TubeGeometry(curve, Math.max(pts.length * 2, 16), state.drawing.thickness, 8, false);
  const tubeMat = new THREE.MeshStandardMaterial({
    color: state.color,
    emissive: new THREE.Color(state.color).multiplyScalar(0.3),
    emissiveIntensity: 0.8,
    roughness: 0.3,
    metalness: 0.4
  });
  const tube = new THREE.Mesh(tubeGeom, tubeMat);
  state.scene.add(tube);
  state.drawing.strokes.push(tube);
  state.drawing.currentPoints = [];
  state.drawing.currentLine = null;
  updateCounter();
}

// --------- 4. Portal ---------
function initPortalSceneResources() {
  // Shader-based portal doesn't need separate scenes
  state.portalSceneType = state.portalSceneType || 'nebula';
}

function placePortal(pos, quat) {
  // Remove old portals
  state.objects.forEach(o => state.scene.remove(o));
  state.objects = [];

  // Create portal ring + masked sphere interior
  const group = new THREE.Group();
  group.position.copy(pos);
  group.position.y += 0.5;
  group.quaternion.copy(quat);

  // Outer ring
  const ringGeom = new THREE.TorusGeometry(0.45, 0.03, 16, 64);
  const ringMat = new THREE.MeshStandardMaterial({
    color: 0xff8c42,
    emissive: 0xff8c42,
    emissiveIntensity: 1.2,
    metalness: 0.8,
    roughness: 0.2
  });
  const ring = new THREE.Mesh(ringGeom, ringMat);
  group.add(ring);

  // Portal interior using shader that shows depth
  const sceneType = state.portalSceneType || 'nebula';
  let portalColor;
  switch(sceneType) {
    case 'ocean': portalColor = 0x006a80; break;
    case 'matrix': portalColor = 0x00ff66; break;
    default: portalColor = 0x3a2080;
  }
  const portalGeom = new THREE.CircleGeometry(0.43, 48);
  const portalMat = new THREE.ShaderMaterial({
    uniforms: {
      time: { value: 0 },
      portalColor: { value: new THREE.Color(portalColor) }
    },
    vertexShader: `
      varying vec2 vUv;
      void main() {
        vUv = uv;
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `,
    fragmentShader: `
      uniform float time;
      uniform vec3 portalColor;
      varying vec2 vUv;
      void main() {
        vec2 p = vUv - 0.5;
        float r = length(p) * 2.0;
        float angle = atan(p.y, p.x);
        float swirl = sin(angle * 6.0 + time * 2.0 - r * 8.0) * 0.5 + 0.5;
        float radial = sin(r * 20.0 - time * 3.0) * 0.3 + 0.7;
        vec3 col = portalColor * swirl * radial;
        col += vec3(0.1, 0.05, 0.0) * (1.0 - r);
        gl_FragColor = vec4(col, 1.0 - pow(r, 3.0));
      }
    `,
    transparent: true,
    side: THREE.DoubleSide
  });
  const portalInner = new THREE.Mesh(portalGeom, portalMat);
  group.add(portalInner);

  group.userData.portalMat = portalMat;
  group.userData.portalType = sceneType;

  state.scene.add(group);
  state.objects.push(group);

  // Add point light at portal
  const light = new THREE.PointLight(portalColor, 2, 2);
  group.add(light);
}

// --------- 5. Physics ---------
function handlePhysicsSelect(pos, quat) {
  if (!state.physics.floorSet) {
    state.physics.floorY = pos.y;
    state.physics.floorSet = true;

    // Visualize floor plane
    const floorGeom = new THREE.RingGeometry(0.3, 0.35, 32).rotateX(-Math.PI / 2);
    const floorMat = new THREE.MeshBasicMaterial({ color: 0x5eead4, transparent: true, opacity: 0.6 });
    const floor = new THREE.Mesh(floorGeom, floorMat);
    floor.position.copy(pos);
    state.scene.add(floor);
    state.objects.push(floor);

    toast('地板已設定，再點擊丟出球體');
    return;
  }

  shootBall();
}

function shootBall() {
  if (!state.physics.floorSet) {
    toast('請先點擊地面設定基準');
    return;
  }

  const { pos: camPos, quat: camQuat } = getCameraPose();
  const forward = new THREE.Vector3(0, 0, -1).applyQuaternion(camQuat);

  const ballGeom = new THREE.SphereGeometry(0.04, 16, 12);
  const color = new THREE.Color(state.color);
  const ballMat = new THREE.MeshStandardMaterial({
    color,
    metalness: 0.6,
    roughness: 0.3,
    emissive: color,
    emissiveIntensity: 0.2
  });
  const ball = new THREE.Mesh(ballGeom, ballMat);
  ball.position.copy(camPos).add(forward.clone().multiplyScalar(0.3));

  ball.userData = {
    velocity: forward.clone().multiplyScalar(2.5).add(new THREE.Vector3(0, 1, 0)),
    radius: 0.04,
    bounces: 0
  };

  state.scene.add(ball);
  state.physics.balls.push(ball);
  updateCounter();
}

function updatePhysics(dt) {
  if (!state.physics.floorSet) return;
  const g = 9.8;

  state.physics.balls.forEach(b => {
    b.userData.velocity.y -= g * dt;
    b.position.addScaledVector(b.userData.velocity, dt);

    // Floor bounce
    if (b.position.y < state.physics.floorY + b.userData.radius) {
      b.position.y = state.physics.floorY + b.userData.radius;
      b.userData.velocity.y *= -0.55;
      b.userData.velocity.x *= 0.85;
      b.userData.velocity.z *= 0.85;
      b.userData.bounces++;

      // Stop if low energy
      if (Math.abs(b.userData.velocity.y) < 0.2 && b.userData.bounces > 3) {
        b.userData.velocity.set(0, 0, 0);
      }
    }

    // Ball-ball collision (simple)
    for (let j = 0; j < state.physics.balls.length; j++) {
      const b2 = state.physics.balls[j];
      if (b2 === b) continue;
      const d = b.position.distanceTo(b2.position);
      const minD = b.userData.radius + b2.userData.radius;
      if (d < minD && d > 0) {
        const normal = b.position.clone().sub(b2.position).normalize();
        const overlap = minD - d;
        b.position.addScaledVector(normal, overlap / 2);
        b2.position.addScaledVector(normal, -overlap / 2);
        // Exchange velocities along normal
        const v1n = b.userData.velocity.dot(normal);
        const v2n = b2.userData.velocity.dot(normal);
        b.userData.velocity.addScaledVector(normal, (v2n - v1n) * 0.8);
        b2.userData.velocity.addScaledVector(normal, (v1n - v2n) * 0.8);
      }
    }
  });
}

// --------- 6. Laser ---------
function fireLaser(pos, quat) {
  const { pos: camPos, quat: camQuat } = getCameraPose();

  const mode = state.laser.mode;
  const targets = [];

  if (mode === 'spread') {
    for (let i = -2; i <= 2; i++) {
      const spreadQuat = camQuat.clone();
      const offset = new THREE.Quaternion().setFromEuler(new THREE.Euler(0, i * 0.1, 0));
      spreadQuat.multiply(offset);
      const forward = new THREE.Vector3(0, 0, -1).applyQuaternion(spreadQuat);
      targets.push(forward);
    }
  } else {
    const forward = new THREE.Vector3(0, 0, -1).applyQuaternion(camQuat);
    targets.push(forward);
  }

  targets.forEach(forward => {
    const endPoint = camPos.clone().add(forward.clone().multiplyScalar(5));
    const color = new THREE.Color(state.color);

    const group = new THREE.Group();

    // Beam (cylinder)
    const length = 5;
    const beamGeom = new THREE.CylinderGeometry(0.006, 0.006, length, 8);
    beamGeom.rotateX(Math.PI / 2);
    const beamMat = new THREE.MeshBasicMaterial({
      color,
      transparent: true,
      opacity: 0.9,
      blending: THREE.AdditiveBlending
    });
    const beam = new THREE.Mesh(beamGeom, beamMat);
    beam.position.copy(camPos).add(forward.clone().multiplyScalar(length / 2));
    beam.lookAt(endPoint);
    beam.rotateX(Math.PI / 2);
    group.add(beam);

    // Impact sphere
    const impactGeom = new THREE.SphereGeometry(0.08, 12, 8);
    const impactMat = new THREE.MeshBasicMaterial({
      color,
      transparent: true,
      opacity: 0.8,
      blending: THREE.AdditiveBlending
    });
    const impact = new THREE.Mesh(impactGeom, impactMat);
    impact.position.copy(endPoint);
    group.add(impact);

    // Light
    const light = new THREE.PointLight(color, 1, 1);
    light.position.copy(endPoint);
    group.add(light);

    group.userData.life = 0;
    group.userData.maxLife = 0.7;
    group.userData.camPos = camPos.clone();
    group.userData.forward = forward.clone();
    group.userData.impact = impact;
    group.userData.light = light;
    group.userData.beam = beam;

    state.scene.add(group);
    state.laser.shots.push(group);
  });

  updateCounter();
}

function updateLasers(dt) {
  state.laser.shots = state.laser.shots.filter(s => {
    s.userData.life += dt;
    const t = s.userData.life / s.userData.maxLife;
    if (t >= 1) {
      state.scene.remove(s);
      return false;
    }
    const opacity = Math.max(0, 1 - t);
    s.userData.beam.material.opacity = opacity * 0.9;
    s.userData.impact.material.opacity = opacity;
    s.userData.impact.scale.setScalar(1 + t * 2);
    s.userData.light.intensity = opacity * 1;
    return true;
  });

  if (state.laser.holding && state.laser.mode === 'rapid') {
    state.laser.rapidTimer = (state.laser.rapidTimer || 0) + dt;
    if (state.laser.rapidTimer > 0.12) {
      state.laser.rapidTimer = 0;
      fireLaser();
    }
  }
}

// --------- 7. Particles ---------
function placeEmitter(pos) {
  const preset = state.particles.preset;
  const count = 400;
  const positions = new Float32Array(count * 3);
  const velocities = new Float32Array(count * 3);
  const lifetimes = new Float32Array(count);
  const sizes = new Float32Array(count);

  for (let i = 0; i < count; i++) {
    positions[i * 3] = 0;
    positions[i * 3 + 1] = 0;
    positions[i * 3 + 2] = 0;
    resetParticle(i, positions, velocities, lifetimes, sizes, preset);
  }

  const geom = new THREE.BufferGeometry();
  geom.setAttribute('position', new THREE.BufferAttribute(positions, 3));
  geom.setAttribute('size', new THREE.BufferAttribute(sizes, 1));

  let color;
  switch (preset) {
    case 'fire': color = new THREE.Color(0xff6a1a); break;
    case 'snow': color = new THREE.Color(0xeeeeff); break;
    case 'smoke': color = new THREE.Color(0x666666); break;
    default: color = new THREE.Color(state.color);
  }

  const mat = new THREE.PointsMaterial({
    color,
    size: 0.04,
    transparent: true,
    opacity: 0.85,
    blending: preset === 'fire' ? THREE.AdditiveBlending : THREE.NormalBlending,
    depthWrite: false,
    sizeAttenuation: true
  });

  const points = new THREE.Points(geom, mat);
  points.position.copy(pos);
  points.userData = { velocities, lifetimes, sizes, count, preset, color };

  state.scene.add(points);
  state.particles.emitters.push(points);
  updateCounter();
}

function resetParticle(i, pos, vel, life, size, preset) {
  pos[i * 3] = (Math.random() - 0.5) * 0.02;
  pos[i * 3 + 1] = 0;
  pos[i * 3 + 2] = (Math.random() - 0.5) * 0.02;

  if (preset === 'fountain') {
    const speed = 1.5 + Math.random();
    const angle = Math.random() * Math.PI * 2;
    const spread = Math.random() * 0.3;
    vel[i * 3] = Math.cos(angle) * spread;
    vel[i * 3 + 1] = speed;
    vel[i * 3 + 2] = Math.sin(angle) * spread;
    life[i] = 1.5 + Math.random() * 0.5;
  } else if (preset === 'fire') {
    vel[i * 3] = (Math.random() - 0.5) * 0.3;
    vel[i * 3 + 1] = 0.5 + Math.random() * 0.5;
    vel[i * 3 + 2] = (Math.random() - 0.5) * 0.3;
    life[i] = 0.8 + Math.random() * 0.4;
  } else if (preset === 'snow') {
    pos[i * 3] = (Math.random() - 0.5) * 2;
    pos[i * 3 + 1] = 1 + Math.random() * 0.5;
    pos[i * 3 + 2] = (Math.random() - 0.5) * 2;
    vel[i * 3] = (Math.random() - 0.5) * 0.1;
    vel[i * 3 + 1] = -0.2 - Math.random() * 0.3;
    vel[i * 3 + 2] = (Math.random() - 0.5) * 0.1;
    life[i] = 3 + Math.random() * 2;
  } else if (preset === 'smoke') {
    vel[i * 3] = (Math.random() - 0.5) * 0.2;
    vel[i * 3 + 1] = 0.3 + Math.random() * 0.3;
    vel[i * 3 + 2] = (Math.random() - 0.5) * 0.2;
    life[i] = 2 + Math.random();
  }
  size[i] = 0.5 + Math.random() * 1.5;
}

function updateParticles(dt) {
  state.particles.emitters.forEach(em => {
    const ud = em.userData;
    const pos = em.geometry.attributes.position.array;
    const vel = ud.velocities;
    const life = ud.lifetimes;

    for (let i = 0; i < ud.count; i++) {
      life[i] -= dt;
      if (life[i] <= 0) {
        resetParticle(i, pos, vel, life, ud.sizes, ud.preset);
        continue;
      }
      pos[i * 3] += vel[i * 3] * dt;
      pos[i * 3 + 1] += vel[i * 3 + 1] * dt;
      pos[i * 3 + 2] += vel[i * 3 + 2] * dt;

      if (ud.preset !== 'snow') {
        vel[i * 3 + 1] -= 2 * dt;  // gravity
      }
      if (ud.preset === 'smoke' || ud.preset === 'fire') {
        // Buoyancy reduces over life
      }
    }
    em.geometry.attributes.position.needsUpdate = true;
  });
}

// --------- 8. Virtual Pet ---------
function placePet(pos) {
  const group = new THREE.Group();
  const color = new THREE.Color(state.color);

  // Body
  const bodyGeom = new THREE.SphereGeometry(0.08, 20, 16);
  const bodyMat = new THREE.MeshStandardMaterial({
    color,
    roughness: 0.4,
    metalness: 0.1
  });
  const body = new THREE.Mesh(bodyGeom, bodyMat);
  group.add(body);

  // Eyes
  const eyeGeom = new THREE.SphereGeometry(0.015, 8, 6);
  const eyeMat = new THREE.MeshBasicMaterial({ color: 0xffffff });
  const pupilMat = new THREE.MeshBasicMaterial({ color: 0x000000 });
  const eyeL = new THREE.Mesh(eyeGeom, eyeMat);
  const eyeR = new THREE.Mesh(eyeGeom, eyeMat);
  eyeL.position.set(-0.025, 0.02, 0.07);
  eyeR.position.set(0.025, 0.02, 0.07);
  const pupilL = new THREE.Mesh(new THREE.SphereGeometry(0.008, 6, 4), pupilMat);
  const pupilR = new THREE.Mesh(new THREE.SphereGeometry(0.008, 6, 4), pupilMat);
  pupilL.position.set(-0.025, 0.02, 0.082);
  pupilR.position.set(0.025, 0.02, 0.082);
  body.add(eyeL); body.add(eyeR);
  body.add(pupilL); body.add(pupilR);

  // Ears (cones)
  const earGeom = new THREE.ConeGeometry(0.025, 0.05, 8);
  const earL = new THREE.Mesh(earGeom, bodyMat);
  const earR = new THREE.Mesh(earGeom, bodyMat);
  earL.position.set(-0.04, 0.07, 0);
  earR.position.set(0.04, 0.07, 0);
  earL.rotation.z = 0.3;
  earR.rotation.z = -0.3;
  body.add(earL); body.add(earR);

  // Position
  group.position.copy(pos);
  group.position.y += 0.08;

  group.userData = {
    targetPos: pos.clone(),
    speed: 0.3,
    homePos: pos.clone(),
    bounceOffset: Math.random() * Math.PI * 2,
    wanderTimer: 0,
    eyeL: pupilL,
    eyeR: pupilR,
    body,
    trickTimer: 0
  };

  state.scene.add(group);
  state.pet.pets.push(group);
  updateCounter();
}

function updatePets(dt, t) {
  state.pet.pets.forEach(pet => {
    const ud = pet.userData;

    // Wander
    ud.wanderTimer -= dt;
    if (ud.wanderTimer <= 0) {
      const angle = Math.random() * Math.PI * 2;
      const dist = 0.3 + Math.random() * 0.5;
      ud.targetPos = ud.homePos.clone();
      ud.targetPos.x += Math.cos(angle) * dist;
      ud.targetPos.z += Math.sin(angle) * dist;
      ud.wanderTimer = 2 + Math.random() * 3;
    }

    // Move towards target
    const diff = ud.targetPos.clone().sub(pet.position);
    diff.y = 0;
    const dist = diff.length();
    if (dist > 0.01) {
      diff.normalize();
      pet.position.x += diff.x * ud.speed * dt;
      pet.position.z += diff.z * ud.speed * dt;
      // Face direction
      pet.rotation.y = Math.atan2(diff.x, diff.z);
    }

    // Bounce
    const bounce = Math.abs(Math.sin(t * 0.005 + ud.bounceOffset)) * 0.015;
    pet.position.y = ud.homePos.y + 0.08 + bounce;
    ud.body.rotation.z = Math.sin(t * 0.005 + ud.bounceOffset) * 0.1;

    // Trick
    if (ud.trickTimer > 0) {
      ud.trickTimer -= dt;
      const trickT = 1 - ud.trickTimer / 1.5;
      pet.rotation.y += dt * 8;
      pet.position.y = ud.homePos.y + 0.08 + Math.sin(trickT * Math.PI) * 0.2;
    }

    // Look at camera
    if (Math.random() < 0.01) {
      const { pos: camPos } = getCameraPose();
      const localCam = pet.worldToLocal(camPos.clone());
      const dir = localCam.clone().normalize();
      ud.eyeL.position.set(-0.025 + dir.x * 0.003, 0.02 + dir.y * 0.003, 0.082);
      ud.eyeR.position.set(0.025 + dir.x * 0.003, 0.02 + dir.y * 0.003, 0.082);
    }
  });
}

function petTrick() {
  state.pet.pets.forEach(p => {
    p.userData.trickTimer = 1.5;
  });
  toast('寵物正在表演!');
}

// --------- Update dispatch ---------
function updateExperience(exp, dt, t) {
  switch (exp.id) {
    case 'draw': updateDrawStroke(); break;
    case 'physics': updatePhysics(dt); break;
    case 'laser': updateLasers(dt); break;
    case 'particles': updateParticles(dt); break;
    case 'pet': updatePets(dt, t); break;
    case 'portal':
      state.objects.forEach(p => {
        if (p.userData.portalMat) {
          p.userData.portalMat.uniforms.time.value = t / 1000;
        }
      });
      // update portal scene
      if (state.portalSceneType && state.portalScenes?.[state.portalSceneType]) {
        state.portalScenes[state.portalSceneType].update(dt, t);
      }
      break;
    case 'placement':
      // Subtle rotation
      state.objects.forEach(o => {
        const age = (performance.now() - (o.userData.spawnTime || 0)) / 1000;
        if (age < 0.5) {
          o.scale.setScalar(state.scale * Math.min(1, age * 2));
        }
      });
      break;
  }
}

// --------- Screenshot ---------
function captureScreenshot() {
  if (!state.renderer) return;
  try {
    $('#flash').classList.add('active');
    setTimeout(() => $('#flash').classList.remove('active'), 400);

    // Force render before toDataURL
    state.renderer.render(state.scene, state.camera);
    const dataURL = state.canvas.toDataURL('image/png');

    const a = document.createElement('a');
    a.download = `ar-lab-${state.experience.id}-${Date.now()}.png`;
    a.href = dataURL;
    a.click();
    toast('截圖已儲存');
  } catch (e) {
    toast('截圖失敗: ' + e.message, true);
  }
}

// --------- UI Helpers ---------
let toastTimer;
function toast(msg, isError = false) {
  const t = $('#toast');
  t.textContent = msg;
  t.style.borderColor = isError ? '#f87171' : '#5eead4';
  t.style.color = isError ? '#f87171' : '#5eead4';
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 1800);
}

function showLoader(text = 'LOADING') {
  $('#loader-text').textContent = text;
  $('#loader').classList.add('active');
}
function hideLoader() {
  $('#loader').classList.remove('active');
}

// --------- Resize ---------
window.addEventListener('resize', () => {
  if (state.renderer && state.camera) {
    state.renderer.setSize(window.innerWidth, window.innerHeight);
    state.camera.aspect = window.innerWidth / window.innerHeight;
    state.camera.updateProjectionMatrix();
  }
});

// --------- Event wiring ---------
$('#ar-back').addEventListener('click', exitExperience);

// --------- Boot ---------
buildMenu();
checkXRSupport();

</script>
