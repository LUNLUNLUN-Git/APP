  try {
    if (state.xrSupported) {
      await initXR();
    } else {
      initFallback();
    }
    initExperience(exp);
    hideLoader();
  } catch (e) {
    console.error(e);
    hideLoader();
    toast('AR 啟動失敗: ' + e.message, true);
    setTimeout(() => exitExperience(), 1500);
  }
}

function resetExperienceState() {
  state.objects = [];
  state.drawing = { isDrawing: false, current: null, strokes: [], thickness: 0.008 };
  state.measure = { points: [], lines: [] };
  state.physics = { balls: [], floorY: null, floorSet: false };
  state.laser = { shots: [], mode: 'single', holding: false };
