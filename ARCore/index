// --------- Camera pose helper (handles XR + fallback) ---------
function getCameraPose() {
  const pos = new THREE.Vector3();
  const quat = new THREE.Quaternion();
  if (state.renderer?.xr?.isPresenting) {
    const xrCam = state.renderer.xr.getCamera();
    const cam = (xrCam.cameras && xrCam.cameras[0]) || xrCam;
    cam.getWorldPosition(pos);
    cam.getWorldQuaternion(quat);
  } else if (state.camera) {
    state.camera.getWorldPosition(pos);
    state.camera.getWorldQuaternion(quat);
  }
  return { pos, quat };
}

